# Navicat 本地 MySQL 连接（和 Navicat 里配置一致）
# 格式: mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql://root:你的密码@localhost:3306/iphone_store_my

# 站点 URL — 正式环境必须用 https://你的域名
NEXT_PUBLIC_SITE_URL=https://teumu.online

# Google OAuth（https://console.cloud.google.com → 凭据 → OAuth 客户端）
# 已授权重定向 URI 必须包含：
#   https://teumu.online/api/auth/google/callback
#   http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=你的Google客户端ID
GOOGLE_CLIENT_SECRET=你的Google客户端密钥
NEXT_PUBLIC_GOOGLE_CLIENT_ID=你的Google客户端ID

# 会话签名密钥（随机长字符串，生产环境必改，否则 Cookie 可被伪造）
SESSION_SECRET=请换成至少32位随机字符串

# 后台管理密码（生产环境必改）
ADMIN_PASSWORD=admin123

# PayPal 沙盒（在 https://developer.paypal.com 申请）
# 配置后启用真实 PayPal 支付；留空则使用演示模式
PAYPAL_CLIENT_ID=你的PayPal客户端ID
PAYPAL_CLIENT_SECRET=你的PayPal密钥
PAYPAL_MODE=sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=你的PayPal客户端ID
