{
  "name": "iphone-store-my",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/start-dev.mjs",
    "dev:clean": "node scripts/start-dev.mjs --clean",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start -p 3000 -H 0.0.0.0",
    "start:prod": "prisma generate && prisma db push && next build && next start -p 3000 -H 0.0.0.0",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:check": "node scripts/check-db.mjs",
    "db:seed": "prisma db seed",
    "db:setup": "prisma db push && prisma db seed",
    "setup:db": "node scripts/setup-all.mjs",
    "setup": "copy .env.local.example .env.local && notepad .env.local"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "next": "^15.3.3",
    "opencc-js": "^1.3.1",
    "prisma": "5.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
