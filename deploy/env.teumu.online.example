# teumu.online 生产环境
# 复制到服务器 /var/www/iphone-store/.env

NODE_ENV=production

NEXT_PUBLIC_SITE_URL=https://teumu.online

DATABASE_URL=mysql://iphone_app:你的MySQL密码@127.0.0.1:3306/iphone_store

SESSION_SECRET=请用 node 生成随机64位十六进制

# 强密码，至少 12 位，勿用 admin123
ADMIN_PASSWORD=请设强密码

# 生产环境私密登录路径（仅你知道），例如 teumu-mgmt-8k2x
# 登录地址变为: https://teumu.online/admin/teumu-mgmt-8k2x
# /admin/login 在生产环境将返回 404
ADMIN_LOGIN_SLUG=teumu-mgmt-请改成你自己的

# PayPal 留空 = 用二维码 + 后台确认收款
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=live
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=
