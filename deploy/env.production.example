# 生产环境 — 复制到服务器 /var/www/iphone-store/.env
# 权限: chmod 600 .env

NODE_ENV=production

# 必须 https + 你的正式域名（影响二维码、支付链接、Cookie 安全）
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# MySQL（建议单独建用户，不要用 root）
DATABASE_URL=mysql://iphone_app:强密码@127.0.0.1:3306/iphone_store

# 随机 32 字节以上（node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"）
SESSION_SECRET=

# 后台密码（必改）
ADMIN_PASSWORD=

# PayPal 正式环境（可选，留空则用二维码 + 后台确认收款）
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=live
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=
